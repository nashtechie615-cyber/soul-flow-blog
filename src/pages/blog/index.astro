---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SHOP_URL, SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <section class="border-b border-sand">
        <div class="mx-auto max-w-6xl px-4 md:px-8 py-14 md:py-20 text-center">
          <p class="text-xs uppercase tracking-[0.3em] text-clay">The Journal</p>
          <h1 class="mt-3 font-display text-4xl md:text-6xl text-ink">Style Notes & Fashion Rituals</h1>
          <p class="mt-5 max-w-2xl mx-auto text-ink-soft">
            Boho-inspired style stories, trend edits, and wardrobe rituals — all designed to help you step softly into your most feminine self.
          </p>
          <a
            href={SHOP_URL}
            class="mt-7 inline-flex items-center gap-2 rounded-full bg-clay px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-white hover:bg-clay-dark transition-colors"
          >
            Shop Soul Flow Apparel
          </a>
        </div>
      </section>

      {featured && (
        <section class="mx-auto max-w-7xl px-4 md:px-8 pt-12">
          <a href={`/blog/${featured.id}/`} class="group grid md:grid-cols-2 gap-6 md:gap-10 items-center">
            {featured.data.heroImage && (
              <div class="aspect-[4/3] overflow-hidden rounded-2xl">
                <img
                  src={featured.data.heroImage}
                  alt={featured.data.title}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div>
              <p class="text-xs uppercase tracking-[0.28em] text-clay">{featured.data.category ?? 'Fashion'}</p>
              <h2 class="mt-3 font-display text-3xl md:text-5xl text-ink leading-tight">{featured.data.title}</h2>
              <p class="mt-4 text-ink-soft leading-relaxed">{featured.data.description}</p>
              <p class="mt-4 text-xs text-muted uppercase tracking-widest">
                <FormattedDate date={featured.data.pubDate} />
              </p>
              <span class="mt-5 inline-block text-sm font-semibold uppercase tracking-[0.22em] text-clay-dark group-hover:text-terracotta">
                Read the Story →
              </span>
            </div>
          </a>
        </section>
      )}

      <section class="mx-auto max-w-7xl px-4 md:px-8 py-16">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
          {rest.map((post) => (
            <a href={`/blog/${post.id}/`} class="group block">
              {post.data.heroImage && (
                <div class="aspect-[4/5] overflow-hidden rounded-xl bg-sand">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </div>
              )}
              <p class="mt-4 text-xs uppercase tracking-[0.28em] text-clay">{post.data.category ?? 'Fashion'}</p>
              <h3 class="mt-2 font-display text-xl md:text-2xl text-ink group-hover:text-clay-dark transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-ink-soft line-clamp-2">{post.data.description}</p>
              <p class="mt-3 text-xs text-muted uppercase tracking-widest">
                <FormattedDate date={post.data.pubDate} />
              </p>
            </a>
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
