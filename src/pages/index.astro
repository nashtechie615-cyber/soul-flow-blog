---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SHOP_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
const latest = rest.slice(0, 6);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <section class="relative">
        <div class="absolute inset-0 bg-gradient-to-b from-sand to-ivory -z-10"></div>
        <div class="mx-auto max-w-6xl px-4 md:px-8 py-20 md:py-28 text-center">
          <p class="text-xs uppercase tracking-[0.32em] text-clay">Soul Flow Apparel Journal</p>
          <h1 class="mt-4 font-display text-4xl md:text-6xl lg:text-7xl text-ink leading-[1.05]">
            Boho style, <span class="italic text-clay">softly written</span>.
          </h1>
          <p class="mt-6 max-w-2xl mx-auto text-lg text-ink-soft">
            Style notes, trend edits, and wardrobe rituals from the world of Soul Flow Apparel — where fashion meets femininity.
          </p>
          <div class="mt-8 flex items-center justify-center gap-4 flex-wrap">
            <a
              href={`${base}blog/`}
              class="inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-ivory hover:bg-clay-dark transition-colors"
            >
              Read the Journal
            </a>
            <a
              href={SHOP_URL}
              class="inline-flex items-center gap-2 rounded-full bg-clay px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-white hover:bg-clay-dark transition-colors"
            >
              Shop the Collection
            </a>
          </div>
        </div>
      </section>

      {featured && (
        <section class="mx-auto max-w-7xl px-4 md:px-8 pb-12">
          <a href={`${base}blog/${featured.id}/`} class="group grid md:grid-cols-2 gap-6 md:gap-12 items-center">
            {featured.data.heroImage && (
              <div class="aspect-[4/3] overflow-hidden rounded-2xl">
                <img
                  src={featured.data.heroImage}
                  alt={featured.data.title}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div>
              <p class="text-xs uppercase tracking-[0.28em] text-clay">Featured · {featured.data.category ?? 'Fashion'}</p>
              <h2 class="mt-3 font-display text-3xl md:text-5xl text-ink leading-tight">{featured.data.title}</h2>
              <p class="mt-4 text-ink-soft">{featured.data.description}</p>
              <p class="mt-4 text-xs text-muted uppercase tracking-widest">
                <FormattedDate date={featured.data.pubDate} />
              </p>
              <span class="mt-5 inline-block text-sm font-semibold uppercase tracking-[0.22em] text-clay-dark group-hover:text-terracotta">
                Read the Story →
              </span>
            </div>
          </a>
        </section>
      )}

      {latest.length > 0 && (
        <section class="mx-auto max-w-7xl px-4 md:px-8 pb-20">
          <div class="flex items-end justify-between mb-8">
            <h2 class="font-display text-3xl md:text-4xl text-ink">Latest Stories</h2>
            <a href={`${base}blog/`} class="text-xs uppercase tracking-[0.22em] text-clay-dark hover:text-terracotta">View all →</a>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {latest.map((post) => (
              <a href={`${base}blog/${post.id}/`} class="group block">
                {post.data.heroImage && (
                  <div class="aspect-[4/5] overflow-hidden rounded-xl bg-sand">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  </div>
                )}
                <p class="mt-3 text-xs uppercase tracking-[0.28em] text-clay">{post.data.category ?? 'Fashion'}</p>
                <h3 class="mt-1 font-display text-xl text-ink group-hover:text-clay-dark transition-colors">
                  {post.data.title}
                </h3>
                <p class="mt-1 text-xs text-muted uppercase tracking-widest">
                  <FormattedDate date={post.data.pubDate} />
                </p>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <Footer />
  </body>
</html>
