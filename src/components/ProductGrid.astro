---
import { SHOP_URL } from '../consts';

export interface Product {
  name: string;
  url: string;
  image: string;
  price?: string;
}

interface Props {
  products: Product[];
  title?: string;
  subtitle?: string;
}

const {
  products,
  title = 'Shop the Story',
  subtitle = 'Hand-picked pieces from Soul Flow Apparel to bring the look home.',
} = Astro.props;
---

<section class="mt-16 border-t border-sand pt-14">
  <div class="text-center max-w-2xl mx-auto px-4">
    <p class="text-xs uppercase tracking-[0.28em] text-clay">Soul Flow Apparel</p>
    <h2 class="mt-3 font-display text-3xl md:text-4xl text-ink">{title}</h2>
    <p class="mt-3 text-ink-soft">{subtitle}</p>
  </div>

  <div class="mt-10 grid grid-cols-2 lg:grid-cols-4 gap-5 md:gap-7">
    {products.map((p) => (
      <a
        href={p.url}
        class="group block"
        target="_blank"
        rel="noopener"
      >
        <div class="aspect-[4/5] overflow-hidden rounded-xl bg-sand">
          <img
            src={p.image}
            alt={p.name}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
        <h3 class="mt-3 font-display text-base md:text-lg text-ink leading-snug line-clamp-2">
          {p.name}
        </h3>
        {p.price && (
          <p class="mt-1 text-sm text-clay-dark">{p.price}</p>
        )}
      </a>
    ))}
  </div>

  <div class="mt-10 text-center">
    <a
      href={SHOP_URL}
      class="inline-flex items-center gap-2 rounded-full bg-ink px-7 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-ivory hover:bg-clay-dark transition-colors"
    >
      Shop All at Soul Flow Apparel
    </a>
  </div>
</section>
