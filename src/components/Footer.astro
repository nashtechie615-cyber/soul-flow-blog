---
import { SHOP_URL } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="mt-24 border-t border-sand bg-sand/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <h3 class="font-display text-2xl text-ink">Soul Flow <span class="italic text-clay">Apparel</span></h3>
        <p class="mt-3 text-sm text-ink-soft leading-relaxed">
          Where fashion meets femininity. Boho-inspired clothing, jewelry, kimonos and accessories for the free-spirited woman.
        </p>
        <a
          href={SHOP_URL}
          class="mt-5 inline-flex items-center gap-2 rounded-full bg-clay px-5 py-2 text-sm font-semibold text-white hover:bg-clay-dark transition-colors"
        >
          Visit the Shop
        </a>
      </div>

      <div>
        <h4 class="font-display text-lg text-ink">Shop</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-ink-soft hover:text-clay" href={`${SHOP_URL}/collections/all`}>All Collections</a></li>
          <li><a class="text-ink-soft hover:text-clay" href={`${SHOP_URL}/collections/kimonos`}>Kimonos</a></li>
          <li><a class="text-ink-soft hover:text-clay" href={`${SHOP_URL}/collections/dresses`}>Dresses</a></li>
          <li><a class="text-ink-soft hover:text-clay" href={`${SHOP_URL}/collections/necklaces`}>Jewelry</a></li>
          <li><a class="text-ink-soft hover:text-clay" href={`${SHOP_URL}/collections/sale`}>Sale</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display text-lg text-ink">Explore</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-ink-soft hover:text-clay" href={`${base}blog/`}>The Journal</a></li>
          <li><a class="text-ink-soft hover:text-clay" href={SHOP_URL}>Home</a></li>
          <li><a class="text-ink-soft hover:text-clay" href={`${SHOP_URL}/pages/contact`}>Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-sand flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted">
      <p>&copy; {year} Soul Flow Apparel. All rights reserved.</p>
      <p>Boho. Effortless. Yours.</p>
    </div>
  </div>
</footer>
