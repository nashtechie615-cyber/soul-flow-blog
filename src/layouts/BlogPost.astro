---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ProductGrid from '../components/ProductGrid.astro';
import { SHOP_URL } from '../consts';

type Data = CollectionEntry<'blog'>['data'];
interface Props extends Data {}

const { title, description, pubDate, updatedDate, heroImage, category, products } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
  </head>
  <body class="min-h-screen flex flex-col bg-ivory">
    <Header />

    <main class="flex-1 w-full">
      <article class="mx-auto max-w-3xl px-4 sm:px-6 py-10 md:py-14">
        <header class="text-center mb-8 md:mb-10">
          {category && (
            <p class="text-xs uppercase tracking-[0.3em] text-clay">{category}</p>
          )}
          <h1 class="mt-4 font-display text-3xl md:text-5xl text-ink leading-tight">
            {title}
          </h1>
          <p class="mt-5 text-sm text-muted uppercase tracking-widest">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <>
                {' · Updated '}<FormattedDate date={updatedDate} />
              </>
            )}
          </p>
        </header>

        {heroImage && (
          <figure class="mb-10 md:mb-12">
            <img
              src={heroImage}
              alt={title}
              class="w-full aspect-[16/10] object-cover rounded-2xl shadow-sm"
              fetchpriority="high"
            />
          </figure>
        )}

        <div class="prose-soulflow">
          <p class="text-lg md:text-xl text-ink-soft italic mb-8 !max-w-none">
            {description}
          </p>
          <slot />
        </div>

        <aside class="mt-14 px-6 py-8 rounded-2xl bg-sand/70 text-center">
          <p class="text-xs uppercase tracking-[0.3em] text-clay">Wear the Story</p>
          <h3 class="mt-2 font-display text-2xl md:text-3xl text-ink">Discover your next favorite at Soul Flow Apparel</h3>
          <p class="mt-3 text-ink-soft">Boho-inspired clothing, kimonos, and jewelry curated with intention.</p>
          <a
            href={SHOP_URL}
            class="mt-5 inline-flex items-center gap-2 rounded-full bg-clay px-6 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-white hover:bg-clay-dark transition-colors"
          >
            Shop the Collection
          </a>
        </aside>
      </article>

      {products && products.length > 0 && (
        <div class="mx-auto max-w-5xl px-4 sm:px-6 pb-16">
          <ProductGrid products={products} />
        </div>
      )}
    </main>

    <Footer />
  </body>
</html>
